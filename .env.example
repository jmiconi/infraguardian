# ----------------------------------------------------
# InfraGuardian environment configuration
# Copy this file to .env before starting the stack.
# ----------------------------------------------------

# PostgreSQL connection settings
POSTGRES_HOST=ig-postgres
POSTGRES_PORT=5432
POSTGRES_DB=infraguardian
POSTGRES_USER=igadmin

# Change this password in production environments
POSTGRES_PASSWORD=changeme

# Collector configuration
# Interval in seconds between metric collections
COLLECTOR_INTERVAL=30

      "targets": [
        {
          "dataset": "infraguardian",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n    SELECT\n        collected_at,\n        hostname,\n        network_bytes_recv,\n        LAG(network_bytes_recv) OVER (\n            PARTITION BY hostname\n            ORDER BY collected_at\n        ) AS prev_bytes,\n        EXTRACT(EPOCH FROM (\n            collected_at - LAG(collected_at) OVER (\n                PARTITION BY hostname\n                ORDER BY collected_at\n            )\n        )) AS delta_seconds\n    FROM system_metrics\n    WHERE\n        $__timeFilter(collected_at)\n        AND hostname = '$hostname'\n)\nSELECT\n    collected_at AS \"time\",\n    CASE\n        WHEN prev_bytes IS NULL THEN NULL\n        WHEN delta_seconds IS NULL OR delta_seconds <= 0 THEN NULL\n        WHEN network_bytes_recv < prev_bytes THEN NULL\n        ELSE ROUND((((network_bytes_recv - prev_bytes) * 8.0) / delta_seconds) / 1000000, 3)\n    END AS value\nFROM base\nORDER BY collected_at;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
